{
  "$schema": ".quiltnt/package.schema.json",
  "name": "llqqnt-marked-it",
  "private": true,
  "version": "0.1.0",
  "description": "为 QQNT 提供更轻量的 Markdown 渲染",
  "quiltnt": {
    "manifest": {
      "manifest_version": 4,
      "type": "extension",
      "name": "Marked It",
      "slug": "marked-it",
      "version": null,
      "description": null,
      "icon": "./icon.svg",
      "thumb": "./thumb.svg",
      "authors": [],
      "platform": [
        "win32",
        "linux",
        "darwin"
      ],
      "injects": "tsdown",
      "repository": null
    }
  },
  "scripts": {
    "build": "tsdown",
    "postbuild": "unrun .quiltnt/postbuild.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LateDreamXD/llqqnt-marked-it.git"
  },
  "author": "晚梦 (https://github.com/LateDreamXD)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LateDreamXD/llqqnt-marked-it/issues"
  },
  "homepage": "https://github.com/LateDreamXD/llqqnt-marked-it#readme",
  "devDependencies": {
    "@llqqntuno/liteloader-types": "^1.4.0",
    "@llqqntuno/liteloader-web-components-types": "^1.4.0",
    "@tsdown/css": "^0.21.3",
    "@types/node": "^25.5.0",
    "sass-embedded": "^1.98.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "unplugin-vue": "^7.1.1",
    "unrun": "^0.2.32"
  },
  "dependencies": {
    "github-markdown-css": "^5.9.0",
    "katex": "^0.16.40",
    "marked": "^17.0.5",
    "marked-katex-extension": "^5.1.7",
    "vue": "^3.5.31"
  }
}
