{
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["esnext", "dom"],
    "baseUrl": ".",
    "paths": {
      "@package": ["package.json"],
      "@/*": ["src/renderer/*"]
    }
  },
  "include": [
    "package.json",
    "src/preload/**/*",
    "src/renderer/**/*",
    "src/types/**/*"
  ]
}
