{
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
  },
  "include": [
    "src/preload/**/*",
    "src/renderer/**/*",
    "src/types/**/*"
  ]
}
